  "description": "Layout algorithms for visualizing hierarchical data.",
  "homepage": "https://d3js.org/d3-hierarchy/",
  "repository": {
    "type": "git",
    "url": "https://github.com/d3/d3-hierarchy.git"
  },
  "license": "ISC",
