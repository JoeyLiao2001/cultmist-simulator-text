{
  "name": "d3-geo",
  "version": "3.1.1",
  "description": "Shapes and calculators for spherical coordinates.",
  "homepage": "https://d3js.org/d3-geo/",
  "repository": {
    "type": "git",
    "url": "https://github.com/d3/d3-geo.git"
  },
  "license": "ISC",
